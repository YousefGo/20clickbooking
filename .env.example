# --- Database (Neon Postgres) ---
# Create a project at https://console.neon.tech, copy the pooled connection string.
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# --- Email (Resend) ---
# Create an API key at https://resend.com/api-keys and verify a sending domain.
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="Booking <booking@yourclinic.com>"

# --- Admin panel ---
# Single shared admin password (MVP-level protection, see README "Admin protection" section).
ADMIN_PASSWORD="change-me"
# Random secret used to sign the admin session cookie. Generate with: openssl rand -base64 32
ADMIN_SESSION_SECRET="change-me-too"

# --- Hospital / clinic branding ---
HOSPITAL_NAME_EN="City Hospital"
HOSPITAL_NAME_AR="مستشفى المدينة"
HOSPITAL_ADDRESS_EN="123 Main St, City"
HOSPITAL_ADDRESS_AR="١٢٣ الشارع الرئيسي، المدينة"
HOSPITAL_PHONE="+966500000000"
HOSPITAL_LOGO_URL=""
# IANA timezone the hospital operates in, e.g. Asia/Riyadh, Africa/Cairo
HOSPITAL_TIMEZONE="Asia/Riyadh"

# --- App ---
DEFAULT_LOCALE="ar"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
